const express = require("express");
const router = express.Router();
const db = require("../db");
const auth = require("../middleware/auth");
const logAction = require("../utils/logger");

// GET current user
router.get("/me", auth, (req, res) => {

  logAction(
    "VIEW_PROFILE_REQUEST",
    `user=${req.user.id}`
  );

  db.query(
    "SELECT MemberID, Name, Email, Role FROM member WHERE MemberID = ?",
    [req.user.id],
    (err, result) => {
      if (err) {
        logAction(
          "VIEW_PROFILE_ERROR",
          `user=${req.user.id}`
        );
        return res.status(500).send(err);
      }

      if (result.length === 0) {
        logAction(
          "VIEW_PROFILE_FAILED",
          `user=${req.user.id} NOT_FOUND`
        );
        return res.status(404).send("User not found");
      }

      logAction(
        "VIEW_PROFILE_SUCCESS",
        `user=${req.user.id} role=${result[0].Role}`
      );

      res.json(result[0]);
    }
  );

});

